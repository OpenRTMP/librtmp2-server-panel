# librtmp2-server-panel configuration
# IMPORTANT: Replace ALL values below with secure random secrets before deploying!

# REST API of librtmp2-server (internal / server-side; docker-compose uses http://server:8080)
LRTMP2_API_URL=http://localhost:8080
# HTTP API base URL for copied stats links (browser-reachable; e.g. http://localhost:8080)
LRTMP2_STATS_URL=http://localhost:8080
# Shared API token — must match librtmp2-server (seeded via LRTMP2_API_TOKEN on first startup)
LRTMP2_API_TOKEN=<generate-with-openssl-rand-hex-32>

# Public host/IP that clients use to reach the RTMP listener
LRTMP2_DOMAIN=localhost
# Must match rtmps.bind port in librtmp2-server's config.env. Only used when
# librtmp2-server reports RTMPS as enabled (checked live via /api/v1/health) —
# the panel won't show rtmps:// URLs otherwise.
LRTMP2_RTMPS_PORT=1936
# Must match rtmp.bind port in librtmp2-server's config.env
LRTMP2_RTMP_PORT=1935
# Default RTMP application name new streams are created under
LRTMP2_APP=live

REQUIRE_LOGIN=True
USERNAME=admin
PASSWORD=<generate-strong-password>
SECRET_KEY=<generate-with-python3-secrets-token-hex-32>
# Shared rate-limit store for multi-worker Gunicorn (docker-compose defaults to redis://redis:6379/0).
# Use memory:// only for single-process local dev (python3 app.py).
RATELIMIT_STORAGE_URI=memory://
# Public URL the panel itself is reached at (e.g. https://panel.example.com).
# Used only to auto-detect SESSION_COOKIE_SECURE below when it is unset —
# leave blank if the panel is plain HTTP or you set SESSION_COOKIE_SECURE explicitly.
PANEL_PUBLIC_URL=
# Set True only when the panel is served over HTTPS (default False for HTTP/docker-compose).
# Takes precedence over PANEL_PUBLIC_URL auto-detection when set. Left commented
# out by default so PANEL_PUBLIC_URL auto-detection above actually takes effect —
# uncomment only if you want to force the value explicitly.
# SESSION_COOKIE_SECURE=False
