# librtmp2-server-panel configuration
# IMPORTANT: Replace ALL placeholder values below with secure random secrets before deploying.

# REST API of librtmp2-server (internal / server-side).
# The standalone compose.quickstart.yml stack overrides this with http://openrtmp-server:8080.
LRTMP2_API_URL=http://localhost:8080
# HTTP API base URL for copied stats links (browser-reachable; e.g. http://localhost:8080).
LRTMP2_STATS_URL=http://localhost:8080
# Shared API token — must match librtmp2-server.
# Docker passes this as a real process environment variable and the server stores it
# in SQLite on first startup.
LRTMP2_API_TOKEN=<generate-with-openssl-rand-hex-32>

# Public host/IP that clients use to reach the RTMP listener.
LRTMP2_DOMAIN=localhost
# Must match the RTMPS listener port. The panel only shows RTMPS URLs when the
# server reports RTMPS as enabled through /api/v1/health.
LRTMP2_RTMPS_PORT=1936
# Must match the RTMP listener port.
LRTMP2_RTMP_PORT=1935
# Default RTMP application name for new streams.
LRTMP2_APP=live

REQUIRE_LOGIN=True
# Required when REQUIRE_LOGIN=False — acknowledges unauthenticated admin access.
# ALLOW_INSECURE_NO_LOGIN=1
USERNAME=admin
PASSWORD=<generate-strong-password>
SECRET_KEY=<generate-with-python3-secrets-token-hex-32>
# Shared rate-limit store for multi-worker Gunicorn.
# compose.quickstart.yml and docker-compose.yml use redis://redis:6379/0.
# For single-process local development (python3 app.py), set:
# RATELIMIT_STORAGE_URI=memory://
# Live stats polling limits for /streams/<id>/stats.json (per minute).
# STATS_RATE_LIMIT_PER_IP=600
# STATS_RATE_LIMIT_PER_STREAM=25
# Public URL the panel itself is reached at (e.g. https://panel.example.com).
# Used to auto-detect SESSION_COOKIE_SECURE when it is unset.
PANEL_PUBLIC_URL=
# Set True only when the panel is served over HTTPS. Leave commented to use
# PANEL_PUBLIC_URL auto-detection, or explicitly set False for plain HTTP.
# SESSION_COOKIE_SECURE=False
