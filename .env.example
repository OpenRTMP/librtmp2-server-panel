# librtmp2-server-panel configuration

# REST API of librtmp2-server (the "http.bind" address)
LRTMP2_API_URL=http://localhost:8080
# Must match auth.api_token in librtmp2-server's config.json
LRTMP2_API_TOKEN=change-me-to-a-secure-token

# Public host/IP that clients use to reach the RTMP listener
LRTMP2_DOMAIN=localhost
# Must match rtmp.bind port in librtmp2-server's config.json
LRTMP2_RTMP_PORT=1935
# Default RTMP application name new streams are created under
LRTMP2_APP=live

REQUIRE_LOGIN=True
USERNAME=admin
PASSWORD=password
SECRET_KEY=change-me-to-a-random-value

# Where the panel stores stream keys locally (librtmp2-server never
# returns publish_key/play_key/stats_key again after creation)
PANEL_DB_PATH=/data/panel.db
